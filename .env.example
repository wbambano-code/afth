ANTHROPIC_API_KEY=sk-ant-xxxxxx
PORT=3000
ADMIN_PASSWORD=change-me-please

# URL publique du site (utilisée pour générer les liens d'activation / reset mdp)
APP_URL=http://localhost:3000

# SMTP pour envoi emails (activation, reset mdp, désabonnement)
# Si SMTP_HOST est vide, les emails sont loggés dans la console serveur au lieu d'être envoyés.
# Exemple Gmail : SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 / SMTP_SECURE=false / SMTP_USER=toi@gmail.com / SMTP_PASS=ton-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AFTh <no-reply@afth.asso.fr>"
